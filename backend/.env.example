PORT=4000
NODE_ENV=development

# Company defaults (used when fields are omitted in requests)
COMPANY_NAME=Raahi
COMPANY_LOGO_URL=http://localhost:4000/assets/logos/raahi_logo.png
COMPANY_ADDRESS=123 Startup Street, San Francisco, CA
SUPPORT_EMAIL=hello@raahi.com
SENDER_NAME=Raahi Team
SENDER_TITLE=Customer Success

# SMTP — local dev: use Mailpit (host=localhost, port=1025, no auth)
# Production: your provider's SMTP settings
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Raahi <hello@raahi.com>"

# Comma-separated origins allowed for CORS (frontend URL)
# On Vercel this defaults to https://<VERCEL_URL> automatically
CORS_ORIGINS=http://localhost:5173

# On Vercel, logo defaults to https://<VERCEL_URL>/logos/raahi_logo.png
# Override only if hosting the logo elsewhere (CDN, S3, etc.)
