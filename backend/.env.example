PORT=4000
NODE_ENV=development

# Raahi / raahionrescue.com branding
COMPANY_NAME=Raahi
COMPANY_LOGO_URL=https://www.raahionrescue.com/raahi-logo.png
COMPANY_ADDRESS=
SUPPORT_EMAIL=contactus@raahionrescue.com
SENDER_NAME=Raahi Team
SENDER_TITLE=Customer Success

# Local dev: Mailpit (brew install mailpit && mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Raahi <contactus@raahionrescue.com>"

CORS_ORIGINS=http://localhost:5173

# ── Production (Vercel) — RECOMMENDED: use Resend API ──
# GoDaddy SMTP often blocks Vercel even with the correct password.
# Resend sends from contactus@raahionrescue.com after you verify raahionrescue.com on resend.com
#
#   RESEND_API_KEY=re_xxxxxxxx   ← ADD THIS IN VERCEL (best option)
#
# ── Alternative: GoDaddy SMTP (often blocked on Vercel) ──
#   SMTP_PASS=<GoDaddy password for contactus@raahionrescue.com>
#   SMTP_PORT=587
#   SMTP_SECURE=false
