PORT=4000
NODE_ENV=development

# Raahi / raahionrescue.com branding
COMPANY_NAME=Raahi
COMPANY_LOGO_URL=https://www.raahionrescue.com/raahi-logo.png
COMPANY_ADDRESS=
SUPPORT_EMAIL=contactus@raahionrescue.com
SENDER_NAME=Raahi Team
SENDER_TITLE=Customer Success

# Local dev: Mailpit (brew install mailpit && mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Raahi <contactus@raahionrescue.com>"

CORS_ORIGINS=http://localhost:5173

# ── Production (Vercel) — GoDaddy email defaults are built-in ──
# You only need to add SMTP_PASS in Vercel (GoDaddy password for contactus@raahionrescue.com):
#
#   SMTP_HOST=smtpout.secureserver.net   (auto)
#   SMTP_PORT=465                        (auto)
#   SMTP_SECURE=true                     (auto)
#   SMTP_USER=contactus@raahionrescue.com  (auto)
#   SMTP_PASS=<your GoDaddy email password>  ← ADD THIS IN VERCEL
#   MAIL_FROM=Raahi <contactus@raahionrescue.com>  (auto)
