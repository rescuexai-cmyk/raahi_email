<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{subject}}</title>
</head>
<body style="margin:0; padding:0; background-color:#f4f4f5; font-family:Arial, Helvetica, sans-serif;">

  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
         style="background-color:#f4f4f5; padding:24px 0;">
    <tr>
      <td align="center">

        <table role="presentation" width="600" cellspacing="0" cellpadding="0" border="0"
               style="background-color:#ffffff; border-radius:8px; overflow:hidden;">

          <tr>
            <td align="center" style="padding:32px 40px 16px; background-color:#ffffff;">
              <img src="{{logoUrl}}" alt="{{companyName}}" width="180" height="auto"
                   style="display:block; border:0; outline:none; background:transparent;" />
            </td>
          </tr>

          <tr>
            <td style="padding:8px 40px 24px; text-align:center;">
              <h1 style="margin:0; font-size:24px; line-height:1.3; color:#111827;">
                {{emailTitle}}
              </h1>
              {{#if emailSubtitle}}
              <p style="margin:12px 0 0; font-size:15px; line-height:1.5; color:#6b7280;">
                {{emailSubtitle}}
              </p>
              {{/if}}
            </td>
          </tr>

          <tr>
            <td style="padding:0 40px 32px; font-size:16px; line-height:1.6; color:#374151;">
              <p style="margin:0 0 16px;">Hi {{firstName}},</p>

              <div>{{{contentHtml}}}</div>

              {{#if ctaUrl}}
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:24px 0;">
                <tr>
                  <td align="center" bgcolor="#2563eb" style="border-radius:6px;">
                    <a href="{{ctaUrl}}"
                       style="display:inline-block; padding:12px 24px; color:#ffffff;
                              text-decoration:none; font-weight:600; font-size:15px;">
                      {{ctaLabel}}
                    </a>
                  </td>
                </tr>
              </table>
              {{/if}}
            </td>
          </tr>

          <tr>
            <td style="padding:24px 40px 32px; border-top:1px solid #e5e7eb;">
              <p style="margin:0; font-size:15px; line-height:1.5; color:#374151;">
                Best regards,<br />
                <strong>{{senderName}}</strong><br />
                {{senderTitle}}<br />
                {{companyName}}
              </p>
              <p style="margin:12px 0 0; font-size:13px; color:#9ca3af;">
                {{companyAddress}} ·
                <a href="mailto:{{supportEmail}}" style="color:#6b7280; text-decoration:none;">
                  {{supportEmail}}
                </a>
              </p>
            </td>
          </tr>

        </table>

        <table role="presentation" width="600" cellspacing="0" cellpadding="0" border="0">
          <tr>
            <td align="center" style="padding:16px 40px; font-size:12px; color:#9ca3af;">
              You received this email from {{companyName}}.
            </td>
          </tr>
        </table>

      </td>
    </tr>
  </table>

</body>
</html>
